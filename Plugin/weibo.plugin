#!name=微博去广告
#!desc=微博 & 微博国际版 — 深度净化信息流/评论/发现页/开屏/搜索推广
#!author=3kaiu (规则来源: ddgksf2013/zmqcherish)
#!fallback=备选: RuCu6/zmqcherish (Plugins/Weibo_remove_ads.plugin) — 纯规则无外部脚本依赖
#!homepage=https://github.com/3kaiu/config
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Weibo.png

[Argument]
WEIBO_WEIBO=switch,"true","false",tag=是否开启微博国内版去广告,desc=开启后深度净化微博国内版
WEIBO_INTL=switch,"true","false",tag=是否开启微博国际版去广告,desc=开启后深度净化微博国际版

[Rule]
# 分流 + 广告策略域名
DOMAIN,sdkapp.uve.weibo.com,DIRECT,enable={WEIBO_WEIBO}
DOMAIN,adstrategy.biz.weibo.com,REJECT,enable={WEIBO_WEIBO}

[Rewrite]
# 微博国内版
^https?:\/\/api\.weibo\.cn\/\d\/statuses\/container_detail url script-response-body https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, enable={WEIBO_WEIBO}
^https?:\/\/api\.weibo\.cn\/\d\/statuses\/container_positive url reject-200, enable={WEIBO_WEIBO}
^https?:\/\/api\.weibo\.cn\/\d\/push\/info url reject-200, enable={WEIBO_WEIBO}
^https?:\/\/api\.weibo\.cn\/.*account\/recommend_interesttags url reject-dict, enable={WEIBO_WEIBO}
^https?:\/\/api\.weibo\.cn\/.*\/media_homelist url reject-200, enable={WEIBO_WEIBO}
^https?:\/\/api\.weibo\.cn\/.*finder\/searchbarchange url reject-200, enable={WEIBO_WEIBO}
^https?:\/\/api\.weibo\.cn\/\d\/ad\/preload url reject-dict, enable={WEIBO_WEIBO}
^https?:\/\/api\.weibo\.cn\/\d\/groups\/allgroups\/v\d url script-response-body https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, enable={WEIBO_WEIBO}
^https?:\/\/api\.weibo\.cn\/\d\/profile\/recommend_popuser url reject-dict, enable={WEIBO_WEIBO}
^https?:\/\/boot.*weibo\.com\/v\d\/ad\/preload url script-response-body https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, enable={WEIBO_WEIBO}
^https?:\/\/api\.weibo\.cn\/\d\/\w{5}\/(statuses_unread_hot_timeline|timeline) url script-response-body https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, enable={WEIBO_WEIBO}
^https?:\/\/boot.*weibo\.com\/v\d\/ad\/realtime url reject-200, enable={WEIBO_WEIBO}
^https?:\/\/api\.weibo\.cn\/\d\/video\/tiny_stream_mid_detail url script-response-body https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, enable={WEIBO_WEIBO}
^https?:\/\/api\.weibo\.cn\/.*discovery_home_bottom_getdotinfo url reject-dict, enable={WEIBO_WEIBO}
^https?:\/\/m?api\.weibo\.c(n|om)\/\d/push/daily url reject-dict, enable={WEIBO_WEIBO}
^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/\w{5}\/cardlist url script-response-body https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, enable={WEIBO_WEIBO}
^https?:\/\/(preload-click|preload-impression)\.uve\.weibo\.com\/(interface\/wbpullad\/wbpullad_click\.php|wbapplua\/get_wbpullad_log\.lua) url reject, enable={WEIBO_WEIBO}
^https?:\/\/sdkapp\.uve\.weibo\.com\/interface\/sdk\/sdkconfig\.php url reject, enable={WEIBO_WEIBO}
^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/hot\/hours_spotlight url reject-dict, enable={WEIBO_WEIBO}
^https:\/\/api\.weibo\.cn\/2\/!\/client\/light_skin url script-response-body https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, enable={WEIBO_WEIBO}
^https:\/\/new\.vip\.weibo\.cn\/littleskin\/preview url script-response-body https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, enable={WEIBO_WEIBO}
^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/(searchall|page\?|0flowpage) url script-response-body https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, enable={WEIBO_WEIBO}
^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/statuses/(unread_)?friends(/|_)timeline url script-response-body https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, enable={WEIBO_WEIBO}
^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/groups/timeline url script-response-body https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, enable={WEIBO_WEIBO}
^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/statuses/(container_timeline|unread_hot_timeline|extend|video_mixtimeline|unread_topic_timeline) url script-response-body https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, enable={WEIBO_WEIBO}
^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/profile/(me|container_timeline) url script-response-body https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, enable={WEIBO_WEIBO}
^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/video/(community_tab|remind_info|tiny_stream_video_list) url script-response-body https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, enable={WEIBO_WEIBO}
^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/search/(finder|container_discover) url script-response-body https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, enable={WEIBO_WEIBO}
^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/(checkin/show|\!/live/media_homelist|container/get_item) url script-response-body https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, enable={WEIBO_WEIBO}
^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/cardlist url script-response-body https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, enable={WEIBO_WEIBO}

# 微博国际版
^https?:\/\/weibointl\.api\.weibo\.cn\/portal\.php\?a=open_app url script-response-body https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, enable={WEIBO_INTL}
^https?:\/\/api\.weibo\.cn\/\d\/cardlist\?v_f=.*Weibo_intl url reject-dict, enable={WEIBO_INTL}
^https?:\/\/weibointl\.api\.weibo\.c(n|om)\/portal\.php\?a=hot_search_users url reject-dict, enable={WEIBO_INTL}
^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/ad\/weibointl\? url reject-dict, enable={WEIBO_INTL}
^https?:\/\/weibointl\.api\.weibo\.c(n|om)\/portal\.php.*a=get_searching_info url script-response-body https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_search_info.json, enable={WEIBO_INTL}
^https?:\/\/weibointl\.api\.weibo\.c(n|om)\/portal\.php.*a=get_coopen_ads url script-response-body https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, enable={WEIBO_INTL}
^https?:\/\/(sdk|wb)app\.uve\.weibo\.com(\/interface\/sdk\/sdkad\.php|\/wbapplua\/wbpullad\.lua) url script-response-body https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, enable={WEIBO_INTL}
^https?:\/\/weibointl\.api\.weibo\.c(n|om)\/portal\.php\?a=trends url script-response-body https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, enable={WEIBO_INTL}
^https?:\/\/weibointl\.api\.weibo\.cn\/portal\.php\?a=user_center url script-response-body https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, enable={WEIBO_INTL}
^https?:\/\/weibointl\.api\.weibo\.c(n|om)\/portal\.php\?a=search_topic url script-response-body https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, enable={WEIBO_INTL}

[MitM]
hostname = %APPEND% api.weibo.*, *.api.weibo.*, mapi.weibo.*, *.uve.weibo.com, new.vip.weibo.cn, boot.biz.weibo.com