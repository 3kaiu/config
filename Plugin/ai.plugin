#!name=AI 服务分流
#!desc=ChatGPT · Claude · Gemini · Perplexity · Copilot 等 AI 服务走 Proxy 代理策略组
#!author=3kaiu
#!homepage=https://github.com/3kaiu/config
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Bot.png

[Rule]
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OpenAI (ChatGPT / DALL-E / Sora / API)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DOMAIN-SUFFIX, openai.com, Proxy
DOMAIN-SUFFIX, ai.com, Proxy
DOMAIN-SUFFIX, chatgpt.com, Proxy
DOMAIN-SUFFIX, oaiusercontent.com, Proxy
DOMAIN-SUFFIX, oaistatic.com, Proxy
DOMAIN-SUFFIX, openaiapi-site.azureedge.net, Proxy
DOMAIN-SUFFIX, openaicom-api-bdcpf8c6d2e9b8.azurefd.net, Proxy
DOMAIN-SUFFIX, auth0.openai.com, Proxy
DOMAIN-KEYWORD, openai, Proxy

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Anthropic (Claude / API)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DOMAIN-SUFFIX, anthropic.com, Proxy
DOMAIN-SUFFIX, claude.ai, Proxy

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Google AI (Gemini / AI Studio / PaLM)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DOMAIN-SUFFIX, gemini.google.com, Proxy
DOMAIN-SUFFIX, bard.google.com, Proxy
DOMAIN-SUFFIX, aistudio.google.com, Proxy
DOMAIN-SUFFIX, makersuite.google.com, Proxy
DOMAIN-SUFFIX, generativelanguage.googleapis.com, Proxy
DOMAIN-SUFFIX, deepmind.google, Proxy
DOMAIN-SUFFIX, deepmind.com, Proxy

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 其他 AI 服务
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DOMAIN-SUFFIX, perplexity.ai, Proxy
DOMAIN-SUFFIX, mistral.ai, Proxy
DOMAIN-SUFFIX, groq.com, Proxy
DOMAIN-SUFFIX, cohere.com, Proxy
DOMAIN-SUFFIX, huggingface.co, Proxy
DOMAIN-SUFFIX, replicate.com, Proxy
DOMAIN-SUFFIX, together.ai, Proxy
DOMAIN-SUFFIX, fireworks.ai, Proxy

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AI 编程工具 (Cursor / Copilot / Windsurf)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DOMAIN-SUFFIX, cursor.sh, Proxy
DOMAIN-SUFFIX, cursor.com, Proxy
DOMAIN-SUFFIX, copilot.microsoft.com, Proxy
DOMAIN, github.copilot.com, Proxy
DOMAIN-SUFFIX, codeium.com, Proxy
DOMAIN-SUFFIX, windsurf.ai, Proxy
DOMAIN-SUFFIX, supermaven.com, Proxy
